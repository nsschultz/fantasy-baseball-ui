    "sonarqube-scanner": "^3.5.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  },
  "scripts": {
    "build": "vite build",
    "ci": "npm run lint && npm run test && npm run sonar",
    "lint": "eslint src",
    "sonar": "node sonar-project.js",
    "start": "chmod +x ./env.sh && ./env.sh && cp env-config.js public/ && vite",
    "test": "CI=true jest --coverage --testResultsProcessor jest-sonar-reporter --detectOpenHandles",
    "type-check": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jestSonar": {
    "reportPath": "reports",
    "reportFile": "test-report.xml",
    "indent": 4
  }
}
